{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the flash sale.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the product."
        },
        "price": {
          "type": "number",
          "description": "The discounted price of the product."
        },
        "stock": {
          "type": "number",
          "description": "The current available stock quantity."
        },
        "originalPrice": {
          "type": "number",
          "description": "The original price before discount."
        },
        "image": {
          "type": "string",
          "description": "URL of the product image."
        }
      },
      "required": ["name", "description", "price", "stock", "originalPrice", "image"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed checkout order.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who placed the order (or anonymous ID)."
        },
        "items": {
          "type": "array",
          "description": "List of items purchased.",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "total": {
          "type": "number",
          "description": "Total cost of the order."
        },
        "createdAt": {
          "type": "timestamp",
          "description": "When the order was placed."
        }
      },
      "required": ["userId", "items", "total", "createdAt"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products in the flash sale."
    },
    "orders": {
      "schema": "Order",
      "description": "Collection of completed orders."
    }
  }
}
